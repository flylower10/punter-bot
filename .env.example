# WhatsApp group chat ID (get from bridge logs when you first message the group)
# For multiple groups, use GROUP_CHAT_IDS instead (comma-separated)
GROUP_CHAT_ID=your-group-id@g.us
# GROUP_CHAT_IDS=group1@g.us,group2@g.us

# Flask
FLASK_PORT=5001
FLASK_URL=http://127.0.0.1:5001

# Health check (scripts/health_check.py) — pings /health every N seconds
# HEALTH_CHECK_INTERVAL=300

# Node.js bridge (Flask calls this to send messages)
BRIDGE_URL=http://127.0.0.1:3000

# Database
DB_PATH=data/punter_bot.db

# Timezone
TIMEZONE=Europe/Dublin

# Admin phone numbers (WhatsApp format: country+number@c.us)
# ADMIN_PHONE: single admin (Ed). ADMIN_PHONES: comma-separated list (overrides ADMIN_PHONE)
ADMIN_PHONE=353...@c.us
# ADMIN_PHONES=353...@c.us,353...@c.us
SUPERADMIN_PHONE=353...@c.us

# TEST_MODE: admin nicknames for prefix parsing. Default: ed,edmund. Add yours: ed,edmund,aidan
# ADMIN_NICKNAMES=ed,edmund,aidan

# Rotation order (comma-separated nicknames). Overrides DB rotation_position.
# Set to match Ed's order. Example: Kev,Nialler,Nug,Pawn,DA,Ed
# ROTATION_ORDER=Kev,Nialler,Nug,Pawn,DA,Ed

# Test mode (enables prefix parsing: "Kev: pick text"). Set false for production.
TEST_MODE=false

# Telegram alerts (health check sends notifications here)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# LLM personality (Groq free API)
LLM_ENABLED=false
GROQ_API_KEY=your-groq-api-key
